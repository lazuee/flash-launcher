#!/bin/bash
# PKG Post-installation Script

set -e

PRODUCT_NAME="__PRODUCT_NAME__"
INSTALL_PATH="__PRODUCT_INSTALL_PATH__"
APP_PATH="$INSTALL_PATH/$PRODUCT_NAME.app"
NOTIFIER_NAME="$PRODUCT_NAME Notifier"
LOG_BASENAME="${PRODUCT_NAME// /}"
LOG_FILE="/tmp/${LOG_BASENAME}-postinstall.log"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [POSTINSTALL] $1" | tee -a "$LOG_FILE"
}

find_notifier_app() {
    local candidates=(
        "$APP_PATH/Contents/Frameworks/${NOTIFIER_NAME}.app"
        "$APP_PATH/Contents/Resources/app/notifier/${NOTIFIER_NAME}.app"
    )
    local candidate

    for candidate in "${candidates[@]}"; do
        if [[ -d "$candidate" && -x "$candidate/Contents/MacOS/${NOTIFIER_NAME}" ]]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

get_application_bundle_id() {
    local plist_path="$APP_PATH/Contents/Info.plist"

    if [[ -f "$plist_path" ]]; then
        /usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$plist_path" 2>/dev/null || true
    fi
}

show_install_notification() {
    local uid="$1"
    local notifier_app activate_bundle_id

    notifier_app="$(find_notifier_app || true)"
    activate_bundle_id="$(get_application_bundle_id || true)"

    if [[ -z "$notifier_app" ]]; then
        log "WARN: Notifier app not found"
        return 1
    fi

    local args=(
        --title "${PRODUCT_NAME}"
        --content "Installation complete"
    )

    if [[ -n "$activate_bundle_id" ]]; then
        args+=(--activate "$activate_bundle_id")
    fi

    if launchctl asuser "$uid" /usr/bin/open -g -a "$notifier_app" --args "${args[@]}"; then
        log "Displayed installation notification via notifier app"
        return 0
    fi

    log "WARN: Notifier app failed to launch"
    return 1
}

log "Starting ${PRODUCT_NAME} post-installation..."

INSTALLER_SESSION_DIR="${INSTALLER_TEMP:-/tmp}"
ONCE_MARKER="${INSTALLER_SESSION_DIR}/${LOG_BASENAME}-postinstall.once"
if [[ -f "$ONCE_MARKER" ]]; then
    log "Detected duplicate postinstall invocation in the same installer session; skipping duplicate run"
    exit 0
fi

mkdir -p "$INSTALLER_SESSION_DIR" 2>/dev/null || true
touch "$ONCE_MARKER" 2>/dev/null || true

# Verify installation
if [[ ! -d "$APP_PATH" ]]; then
    log "ERROR: Application not found at $APP_PATH"
    exit 1
fi

# 1. Set Ownership (Standard for Applications)
chown -R root:admin "$APP_PATH"

# 2. Define list of paths requiring executable permissions (Matches TS reference)
# These paths are relative to the .app bundle root
EXECUTABLES=(
    "Contents/MacOS/${PRODUCT_NAME}"
    "Contents/Frameworks/Electron Framework.framework/Electron Framework"
    "Contents/Frameworks/${PRODUCT_NAME} Helper.app/Contents/MacOS/${PRODUCT_NAME} Helper"
    "Contents/Frameworks/${PRODUCT_NAME} Helper (GPU).app/Contents/MacOS/${PRODUCT_NAME} Helper (GPU)"
    "Contents/Frameworks/${PRODUCT_NAME} Helper (Plugin).app/Contents/MacOS/${PRODUCT_NAME} Helper (Plugin)"
    "Contents/Frameworks/${PRODUCT_NAME} Helper (Renderer).app/Contents/MacOS/${PRODUCT_NAME} Helper (Renderer)"
)

# 3. Apply chmod 755 to specific executables
log "Applying executable permissions..."
for REL_PATH in "${EXECUTABLES[@]}"; do
    FILE_PATH="$APP_PATH/$REL_PATH"

    if [ -f "$FILE_PATH" ]; then
        chmod 755 "$FILE_PATH"
    else
        log "WARN: Could not chmod ${REL_PATH} (File not found)"
    fi
done

# 4. Remove quarantine attribute recursively (Matches TS: xattr -rd)
# The 'r' flag is critical for nested frameworks/helpers
log "Removing quarantine attributes..."
if xattr -rd com.apple.quarantine "$APP_PATH" 2>/dev/null; then
    log "Removed quarantine attribute from $PRODUCT_NAME.app"
else
    log "WARN: Could not remove quarantine attribute (or none existed)"
fi

log "Post-installation completed successfully"

CURRENT_USER="$(stat -f%Su /dev/console 2>/dev/null || true)"
if [[ -n "$CURRENT_USER" && "$CURRENT_USER" != "root" ]]; then
    CURRENT_UID="$(id -u "$CURRENT_USER")"
    if show_install_notification "$CURRENT_UID"; then
        log "Displayed installation notification for ${CURRENT_USER}"
    else
        log "WARN: Failed to display installation notification for ${CURRENT_USER}"
    fi
else
    log "WARN: Skipped notification because no logged-in console user was found"
fi

exit 0